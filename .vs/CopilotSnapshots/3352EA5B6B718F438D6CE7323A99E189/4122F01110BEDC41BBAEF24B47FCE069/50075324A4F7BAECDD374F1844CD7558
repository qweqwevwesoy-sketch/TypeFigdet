using System.Configuration;
using System.Data;
using System.Windows;
using System.Runtime.InteropServices;
using System.Collections.Generic;

namespace TypeFigdet
{
    /// <summary>
    /// Interaction logic for App.xaml
    /// </summary>
    public partial class App : Application
    {
        private List<Window> _appWindows = new List<Window>();

        public App()
        {
            // Install the outside click detector
            OutsideClickDetector.Install(() =>
            {
                CloseAllWindows();
            });
        }

        public void RegisterWindow(Window window)
        {
            if (!_appWindows.Contains(window))
            {
                _appWindows.Add(window);
            }
        }

        public void UnregisterWindow(Window window)
        {
            _appWindows.Remove(window);
        }

        public List<Window> GetAppWindows()
        {
            return _appWindows;
        }

        public void CloseAllWindows()
        {
            for (int i = _appWindows.Count - 1; i >= 0; i--)
            {
                try
                {
                    _appWindows[i].Close();
                }
                catch { }
            }
        }

        protected override void OnExit(ExitEventArgs e)
        {
            OutsideClickDetector.Uninstall();
            base.OnExit(e);
        }
    }
}
