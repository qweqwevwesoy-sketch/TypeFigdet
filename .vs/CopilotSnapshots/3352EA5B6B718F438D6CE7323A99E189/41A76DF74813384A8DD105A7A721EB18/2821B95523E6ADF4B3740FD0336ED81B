<Window x:Class="TypeFigdet.SettingsWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d"
		Title="Settings" Height="600" Width="400"
		WindowStartupLocation="CenterScreen"
		Background="#F8F9FA"
		Deactivated="SettingsWindow_Deactivated"
		ResizeMode="CanResizeWithGrip">

	<Window.Resources>
		<!-- Brushes -->
		<SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F8F9FA"/>
		<SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
		<SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
		<SolidColorBrush x:Key="AccentHoverBrush" Color="#005A9E"/>
		<SolidColorBrush x:Key="DangerBrush" Color="#F44747"/>
		<SolidColorBrush x:Key="DangerHoverBrush" Color="#D32F2F"/>
		<SolidColorBrush x:Key="TextPrimaryBrush" Color="#2C3E50"/>
		<SolidColorBrush x:Key="TextSecondaryBrush" Color="#7F8C8D"/>
		<SolidColorBrush x:Key="BorderBrush" Color="#E1E5E9"/>

		<!-- Drop Shadow for Cards -->
		<DropShadowEffect x:Key="CardShadow" BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="Black"/>

		<!-- Modern Button Style -->
		<Style x:Key="ModernButton" TargetType="Button">
			<Setter Property="Background" Value="{StaticResource AccentBrush}"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="16,8"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter Property="Background" Value="{StaticResource AccentBrush}"/>
								<Setter Property="RenderTransform">
									<Setter.Value>
										<ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
									</Setter.Value>
								</Setter>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
			<Setter Property="Background" Value="{StaticResource DangerBrush}"/>
			<Setter Property="Foreground" Value="White"/>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="{StaticResource DangerHoverBrush}"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<!-- Modern ComboBox Style -->
		<Style TargetType="ComboBox">
			<Setter Property="Height" Value="36"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
			<Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
			<Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="10,0"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ComboBox">
						<Grid>
							<ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press">
								<ToggleButton.Template>
									<ControlTemplate TargetType="ToggleButton">
										<Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
											<Grid>
												<ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="10,0,30,0"/>
												<Path x:Name="Arrow"
                                                      Fill="{StaticResource TextSecondaryBrush}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"
                                                      Data="M0,0 L4,4 L8,0 Z"/>
											</Grid>
										</Border>
									</ControlTemplate>
								</ToggleButton.Template>
							</ToggleButton>
							<Popup x:Name="Popup"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
								<Border Background="{StaticResource CardBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,2,0,0"
                                        Effect="{StaticResource CardShadow}">
									<ScrollViewer MaxHeight="200">
										<ItemsPresenter/>
									</ScrollViewer>
								</Border>
							</Popup>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Modern Slider Style -->
		<Style TargetType="Slider">
			<Setter Property="Height" Value="30"/>
			<Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
			<Setter Property="Background" Value="{StaticResource BorderBrush}"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Slider">
						<Grid>
							<Track x:Name="PART_Track">
								<Track.DecreaseRepeatButton>
									<RepeatButton Command="Slider.DecreaseLarge" Background="{TemplateBinding Foreground}" BorderThickness="0"/>
								</Track.DecreaseRepeatButton>
								<Track.IncreaseRepeatButton>
									<RepeatButton Command="Slider.IncreaseLarge" Background="{TemplateBinding Background}" BorderThickness="0"/>
								</Track.IncreaseRepeatButton>
								<Track.Thumb>
									<Thumb Width="16" Height="16" Cursor="Hand">
										<Thumb.Template>
											<ControlTemplate TargetType="Thumb">
												<Border Background="{TemplateBinding Foreground}"
                                                        BorderBrush="White"
                                                        BorderThickness="2"
                                                        CornerRadius="8"
                                                        Width="16"
                                                        Height="16"/>
											</ControlTemplate>
										</Thumb.Template>
									</Thumb>
								</Track.Thumb>
							</Track>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Section Header Style -->
		<Style x:Key="SectionHeader" TargetType="TextBlock">
			<Setter Property="FontSize" Value="18"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
			<Setter Property="Margin" Value="0,20,0,12"/>
		</Style>

		<!-- Label Style -->
		<Style x:Key="SettingLabel" TargetType="TextBlock">
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
			<Setter Property="Margin" Value="0,0,0,6"/>
			<Setter Property="FontWeight" Value="Medium"/>
		</Style>
	</Window.Resources>

	<ScrollViewer Background="Transparent"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
		<StackPanel Margin="24">
			<!-- Header -->
			<TextBlock Text="⚙️ Settings"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,20"/>

			<!-- Font Settings Card -->
			<Border Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,0,16"
                    Effect="{StaticResource CardShadow}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
				<StackPanel>
					<TextBlock Text="🔤 Font Settings"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>

					<TextBlock Text="Font Family" Style="{StaticResource SettingLabel}"/>
					<ComboBox x:Name="FontFamilyComboBox" IsEditable="True" Margin="0,0,0,12"/>

					<TextBlock Text="Font Size" Style="{StaticResource SettingLabel}"/>
					<Slider x:Name="FontSizeSlider" Minimum="8" Maximum="72" Value="48" Margin="0,0,0,4"/>
					<TextBlock x:Name="FontSizeLabel" Text="48 pt" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

					<TextBlock Text="Font Color" Style="{StaticResource SettingLabel}"/>
					<Grid Margin="0,0,0,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<Border Grid.Column="0"
                                Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,8"
                                Margin="0,0,12,0">
							<TextBlock x:Name="ColorLabel" Text="Black" Foreground="{StaticResource TextPrimaryBrush}"/>
						</Border>
						<Button x:Name="ColorPickerButton"
                                Grid.Column="1"
                                Content="🎨 Pick"
                                Style="{StaticResource ModernButton}"
                                Width="80"/>
					</Grid>
				</StackPanel>
			</Border>

			<!-- Window Settings Card -->
			<Border Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,0,16"
                    Effect="{StaticResource CardShadow}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
				<StackPanel>
					<TextBlock Text="🖥️ Window Settings"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>

					<TextBlock Text="Window Width" Style="{StaticResource SettingLabel}"/>
					<Slider x:Name="WindowWidthSlider" Minimum="400" Maximum="1200" Value="600" Margin="0,0,0,4"/>
					<TextBlock x:Name="WindowWidthLabel" Text="600 px" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

					<TextBlock Text="Window Height" Style="{StaticResource SettingLabel}"/>
					<Slider x:Name="WindowHeightSlider" Minimum="200" Maximum="800" Value="300" Margin="0,0,0,4"/>
					<TextBlock x:Name="WindowHeightLabel" Text="300 px" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

					<TextBlock Text="Window Opacity" Style="{StaticResource SettingLabel}"/>
					<Slider x:Name="OpacitySlider" Minimum="0.3" Maximum="1.0" Value="1.0" Margin="0,0,0,4"/>
					<TextBlock x:Name="OpacityLabel" Text="100%" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
				</StackPanel>
			</Border>

			<!-- Appearance Card -->
			<Border Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,0,24"
                    Effect="{StaticResource CardShadow}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
				<StackPanel>
					<TextBlock Text="🎨 Appearance"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>

					<TextBlock Text="Background Color" Style="{StaticResource SettingLabel}"/>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<Border Grid.Column="0"
                                Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,8"
                                Margin="0,0,12,0">
							<TextBlock x:Name="BackgroundColorLabel" Text="White" Foreground="{StaticResource TextPrimaryBrush}"/>
						</Border>
						<Button x:Name="BackgroundColorPickerButton"
                                Grid.Column="1"
                                Content="🎨 Pick"
                                Style="{StaticResource ModernButton}"
                                Width="80"/>
					</Grid>
				</StackPanel>
			</Border>

			<!-- Action Buttons -->
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,20">
				<Button Content="✓ Apply"
                        Click="Apply_Click"
                        Style="{StaticResource ModernButton}"
                        Width="100"
                        Margin="0,0,12,0"/>
				<Button Content="✗ Close"
                        Click="Close_Click"
                        Style="{StaticResource DangerButton}"
                        Width="100"/>
			</StackPanel>
		</StackPanel>
	</ScrollViewer>
</Window>