<Window x:Class="TypeFigdet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TypeFigdet"
        mc:Ignorable="d"
        Title="" Height="300" Width="600" WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False" Background="White" MouseDown="Window_MouseDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Rectangle x:Name="TitleBar" Grid.Row="0" Fill="White" MouseDown="TitleBar_MouseDown"/>
        <TextBox x:Name="InputTextBox" Grid.Row="1" TextWrapping="Wrap" FontSize="48" FontFamily="Arial" TextChanged="TextBox_TextChanged_1" BorderThickness="0" Background="Transparent" Padding="10"/>

    </Grid>
</Window>
    