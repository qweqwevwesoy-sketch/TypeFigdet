<Window x:Class="TypeFigdet.SettingsButtonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Height="35" Width="35" AllowsTransparency="True" WindowStyle="None" Background="transparent" 
        ShowInTaskbar="False" ResizeMode="NoResize">
	<Button x:Name="SettingsBtn" Content="⚙" FontSize="16"
        Background="Transparent" BorderThickness="0"
        Foreground="white" Cursor="Hand">
		<Button.Style>
			<Style TargetType="Button">
				<Style.Triggers>
					<Trigger Property="IsMouseOver" Value="True">
						<Setter Property="Background" Value="LightGray"/>
						<Setter Property="Opacity" Value="0.8"/>
					</Trigger>
				</Style.Triggers>
			</Style>
		</Button.Style>
	</Button>
	
</Window>
