<Window x:Class="TypeFigdet.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings" Height="600" Width="400" WindowStartupLocation="CenterScreen" Background="White">
    <ScrollViewer>
        <StackPanel Margin="20">
            <!-- Font Settings -->
            <TextBlock Text="Font Settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock Text="Font Family:" FontSize="12" Margin="0,0,0,5"/>
            <ComboBox x:Name="FontFamilyComboBox" Height="30" Margin="0,0,0,15" IsEditable="True"/>

            <TextBlock Text="Font Size:" FontSize="12" Margin="0,0,0,5"/>
            <Slider x:Name="FontSizeSlider" Minimum="8" Maximum="72" Value="48" Height="30" Margin="0,0,0,5"/>
            <TextBlock x:Name="FontSizeLabel" Text="48 pt" FontSize="12" Margin="0,0,0,15"/>

            <TextBlock Text="Font Color:" FontSize="12" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ColorLabel" Text="Black" Grid.Column="0" VerticalAlignment="Center"/>
                <Button x:Name="ColorPickerButton" Grid.Column="1" Content="Pick" Click="ColorPickerButton_Click" Height="30"/>
            </Grid>

            <!-- Window Settings -->
            <TextBlock Text="Window Settings" FontSize="16" FontWeight="Bold" Margin="0,20,0,10"/>

            <TextBlock Text="Window Width:" FontSize="12" Margin="0,0,0,5"/>
            <Slider x:Name="WindowWidthSlider" Minimum="400" Maximum="1200" Value="600" Height="30" Margin="0,0,0,5"/>
            <TextBlock x:Name="WindowWidthLabel" Text="600" FontSize="12" Margin="0,0,0,15"/>

            <TextBlock Text="Window Height:" FontSize="12" Margin="0,0,0,5"/>
            <Slider x:Name="WindowHeightSlider" Minimum="200" Maximum="800" Value="300" Height="30" Margin="0,0,0,5"/>
            <TextBlock x:Name="WindowHeightLabel" Text="300" FontSize="12" Margin="0,0,0,15"/>

            <!-- Background Color -->
            <TextBlock Text="Background Color:" FontSize="12" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="BackgroundColorLabel" Text="White" Grid.Column="0" VerticalAlignment="Center"/>
                <Button x:Name="BackgroundColorPickerButton" Grid.Column="1" Content="Pick" Click="BackgroundColorPickerButton_Click" Height="30"/>
            </Grid>

            <!-- Opacity -->
            <TextBlock Text="Window Opacity:" FontSize="12" Margin="0,0,0,5"/>
            <Slider x:Name="OpacitySlider" Minimum="0.3" Maximum="1.0" Value="1.0" Height="30" Margin="0,0,0,5"/>
            <TextBlock x:Name="OpacityLabel" Text="100%" FontSize="12" Margin="0,0,0,15"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Right">
                <Button Content="Apply" Click="Apply_Click" Height="35" Width="80" Margin="0,0,10,0" Background="#007ACC" Foreground="White"/>
                <Button Content="Close" Click="Close_Click" Height="35" Width="80" Background="#F44747" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
